rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Sessions collection
    // Only accessible by authenticated service accounts (server-side)
    match /sessions/{sessionId} {
      // Allow read/write from server-side service accounts only
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@.*\\.iam\\.gserviceaccount\\.com');

      // Session messages subcollection
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email.matches('.*@.*\\.iam\\.gserviceaccount\\.com');
      }
    }

    // Analytics events collection
    // Write access for service accounts, read access for analytics service account
    match /analytics_events/{eventId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@.*\\.iam\\.gserviceaccount\\.com');
    }

    // Analytics sessions collection
    // Write access for service accounts, read access for analytics service account
    match /analytics_sessions/{sessionId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@.*\\.iam\\.gserviceaccount\\.com');
    }
  }
}
