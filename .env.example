# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Document Authoring Configuration
DA_ORG=carlossg
DA_REPO=arco

# DA Authentication (S2S - preferred)
DA_CLIENT_ID=
DA_CLIENT_SECRET=
DA_SERVICE_TOKEN=

# DA Authentication (Legacy fallback)
DA_TOKEN=

# Model Configuration
MODEL_PRESET=production

# Feature Flags
# LLM-generated hero copy (set to "false" to use deterministic copy)
LLM_HERO_COPY=true

# Optional: Vertex AI Endpoint for Gemma (requires GPU deployment)
GEMMA_ENDPOINT_ID=

# ── Benchmark (promptfoo) ─────────────────────────────────────────────────────
# promptfoo's vertex: provider reads VERTEX_PROJECT_ID and VERTEX_REGION (not GCP_* vars).
# Set these to the same values as GCP_PROJECT_ID / GCP_LOCATION above.
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-central1
# GCLOUD_TOKEN is needed for Llama 4 MaaS providers (openai: type); refresh with:
#   gcloud auth print-access-token  (expires hourly)
GCLOUD_TOKEN=

# Cerebras — https://cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY=your-cerebras-api-key

# Cloudflare Workers AI
# Account ID: Cloudflare dashboard → right sidebar
# API Token: https://dash.cloudflare.com/profile/api-tokens (Workers AI template)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# AWS Bedrock — credentials are read from ~/.aws/credentials
# Set AWS_PROFILE to select a named profile, or leave unset to use [default]
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
